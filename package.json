{
  "name": "@lupyd/protos",
  "version": "0.1.0",
  "description": "Protocol Buffers for Lupyd",
  "type": "module",
  "main": "./typescript/dist/index.js",
  "types": "./typescript/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./typescript/dist/index.d.ts",
      "import": "./typescript/dist/index.js"
    }
  },
  "scripts": {
    "build-protos": "protoc -I . --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_opt=forceLong=bigint --ts_proto_opt=env=browser --ts_proto_out=typescript/src ./*.proto",
    "build": "tsc -p typescript",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "ts-proto": "^2.1.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0"
  }
}